datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String
  tagline      String
  productCount Int      @default(0)
  featured     Boolean  @default(false)
  gradient     String
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id           String           @id @default(cuid())
  slug         String           @unique
  name         String
  tagline      String
  description  String
  categorySlug String
  basePrice    Float
  customizable Boolean          @default(false)
  tags         String[]
  featured     Boolean          @default(false)
  sizes        String[]
  variants     ProductVariant[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name             String
  color            String
  colorHex         String
  price            Float
  images           String[]
  inStock          Boolean  @default(true)
  stockQuantity    Int      @default(0)
  reorderThreshold Int      @default(5)
}

model DeviceSkinTemplate {
  id           String   @id
  name         String
  brand        String
  type         String
  aspectRatio  Float
  borderRadius Float
  cameraModule Json?
  logoCutout   Json?
  sPenSilo     Boolean  @default(false)
  confidence   String
  notes        String?
  createdAt    DateTime @default(now())
}

model CustomizationTemplate {
  id          String @id @default(cuid())
  productId   String @unique
  mockupImage String
  printArea   Json
  blendMode   String @default("source-over")
}
enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

model User {
  id        String             @id
  email     String             @unique
  fullName  String?
  role      Role               @default(CUSTOMER)
  notes     String?            // staff-only CRM notes
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  addresses Address[]
  orders    Order[]
  designs   CustomizerDesign[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  street    String
  city      String
  state     String
  zip       String
  country   String   @default("India")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Order {
  id                    String      @id @default(cuid())
  userId                String?
  user                  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  total                 Float
  status                String      @default("processing")
  paymentStatus         String      @default("paid")
  shippingAddress       Json
  razorpayOrderId       String?
  razorpayPaymentId     String?
  razorpaySignature     String?
  couponCode            String?
  discount              Float?      @default(0)
  estimatedDeliveryDate DateTime?
  shippingMethod        String?     @default("standard")
  internalNotes         String?     // staff-only, never shown to customer
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  items                 OrderItem[]
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  variantId     String
  quantity      Int
  price         Float
  size          String?
  customization Json?
}

model CustomizerDesign {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  productId   String
  canvasState Json
  previewUrl  String?
  title       String?  @default("My Design")
  createdAt   DateTime @default(now())
}

model Coupon {
  id               String    @id @default(cuid())
  code             String    @unique
  discountType     String    // 'percentage' or 'flat'
  discountValue    Float
  isActive         Boolean   @default(true)
  expiresAt        DateTime?
  maxUses          Int?
  perCustomerLimit Int?
  minOrderValue    Float?    @default(0)
  usageCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model StoreSettings {
  id           String   @id @default("singleton")
  storeName    String   @default("StarBy")
  contactEmail String   @default("")
  logoUrl      String?
  taxRate      Float    @default(0)
  newOrderEmail Boolean @default(true)
  updatedAt    DateTime @updatedAt
}

model ShippingZone {
  id        String   @id @default(cuid())
  name      String
  states    String[]
  rateType  String   // 'flat' | 'per_item'
  rateValue Float
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
